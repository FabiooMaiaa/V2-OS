# Copie para .env.local e preencha com os valores do seu projeto.
# Dashboard do Supabase: Project Settings > API
# Ambas são públicas (prefixo NEXT_PUBLIC_): só a URL e a chave publishable/anon
# podem aparecer aqui. NUNCA coloque a service_role neste arquivo.

# URL raiz do projeto, sem /rest/v1 no fim.
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-publishable-ou-anon
